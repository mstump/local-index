# Voyage AI API key (required for embedding)
# Get yours at https://www.voyageai.com/
VOYAGE_API_KEY=your_voyage_api_key_here

# Log level (default: info)
# Equivalent to --log-level flag. Accepts: trace, debug, info, warn, error
# RUST_LOG takes precedence if both are set.
LOCAL_INDEX_LOG_LEVEL=info

# Directory for index data: LanceDB, tantivy, metadata (default: ~/.local/share/local-index)
# Equivalent to --data-dir flag
# LOCAL_INDEX_DATA_DIR=/path/to/data

# HTTP server bind address for `serve` and `daemon` commands (default: 127.0.0.1:3000)
# Equivalent to --bind flag
# LOCAL_INDEX_BIND=127.0.0.1:3000
